         }
         default: return term_new_int(0);
     }
@@ -795,7 +843,7 @@ int interp_exec_pl_builtin(EXPR_t *goal, Term **env) {
                     return !IS_FAIL_fn(rd);
                 }
                 fprintf(stderr,"prolog: undefined predicate %s/%d\n",fn,arity);
-                return 0;

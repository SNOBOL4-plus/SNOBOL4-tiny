             }
             if (strcmp(fn,"true")==0&&arity==0) return 1;
             if (strcmp(fn,"fail")==0&&arity==0) return 0;
@@ -1999,7 +2047,7 @@ int interp_exec_pl_builtin(EXPR_t *goal, Term **env) {
                 return gok;
             }
             fprintf(stderr,"prolog: undefined predicate %s/%d\n",fn,arity);
-            return 0;
